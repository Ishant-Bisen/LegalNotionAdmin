# ─── Local dev (recommended) ───
# Do NOT set VITE_API_BASE. The app uses http://localhost:5173/api/... and Vite proxies to your backend
# (see vite.config.ts) — same origin in the browser, so CORS does not apply.
#
# Default proxy target:
# VITE_DEV_PROXY_TARGET=http://localhost:3000
#
# If your backend uses another port, change VITE_DEV_PROXY_TARGET and restart `npm run dev`.

# ─── Direct API URL (optional) ───
# Set only if you must call the API host directly from the browser (e.g. phone on LAN). Then the backend
# MUST allow your exact origin with credentials, e.g. FRONTEND_ORIGIN=http://192.168.1.10:5173
# (comma-separated for multiple origins). Example:
# VITE_API_BASE=http://localhost:3000

# Production build (defaults to https://api.legalnotion.in if unset):
# VITE_API_BASE=https://api.legalnotion.in

# VITE_BLOGS_API_PATH=/api/blogs
# VITE_CANDIDATES_API_PATH=/api/candidates
